FROM golang:1.26-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -o /stashy ./cmd/stashy

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /stashy /stashy
COPY --from=build /src/public/ /public/

ENTRYPOINT ["/stashy"]

CMD ["serve"]
